---
import Base from '../layouts/Base.astro';
import { roadStops, getLesson } from '../data/lessons.js';

// Build the cheat-sheet straight from lesson content — stays in sync automatically.
const rows = roadStops.map((s) => {
  const lesson = getLesson(s.slug);
  const takeaway = (lesson?.teachBack || '')
    .replace(/^In one line:\s*/i, '')
    .replace(/^\*|\*$/g, '')
    .trim();
  return {
    id: s.id,
    icon: s.icon,
    title: s.title,
    subtitle: s.subtitle,
    takeaway,
    productMust: lesson?.buildBridge?.replace(/\*\*(.+?)\*\*/g, '$1') || '',
  };
});
---

<Base title="DRC Cheat-Sheet — DRCDrivers">
  <div class="mx-auto mt-6 max-w-3xl">
    <div class="mb-6 flex items-center justify-end print:hidden">
      <button
        id="printBtn"
        class="rounded-lg bg-blue-500 px-4 py-2 text-sm font-medium text-white hover:bg-blue-600"
      >
        🖨️ Print / Save as PDF
      </button>
    </div>

    <article class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm dark:border-slate-700 dark:bg-slate-800 print:border-0 print:bg-white print:shadow-none">
      <header class="border-b border-slate-200 pb-4 dark:border-slate-700">
        <p class="text-xs font-semibold uppercase tracking-widest text-blue-600 dark:text-blue-400">DRCDrivers · Cheat-Sheet</p>
        <h1 class="mt-1 text-2xl font-bold text-slate-900 dark:text-slate-100 print:!text-slate-900">Data Risk &amp; Compliance, end to end</h1>
        <p class="mt-1 text-sm text-slate-500 dark:text-slate-400 print:!text-slate-600">
          The whole road on one page — each stop's takeaway and what your product must do about it.
        </p>
      </header>

      <ol class="mt-5 space-y-4">
        {rows.map((r) => (
          <li class="break-inside-avoid">
            <div class="flex items-baseline gap-2">
              <span class="text-lg">{r.icon}</span>
              <h2 class="font-semibold text-slate-900 dark:text-slate-100 print:!text-slate-900">
                {r.id}. {r.title}
                <span class="ml-1 font-normal text-slate-400">— {r.subtitle}</span>
              </h2>
            </div>
            <p class="mt-1 pl-7 text-sm text-slate-700 dark:text-slate-300 print:!text-slate-800">{r.takeaway}</p>
            <p class="mt-1 pl-7 text-sm text-slate-600 dark:text-slate-300 print:!text-slate-700">
              <span class="font-semibold text-blue-700 dark:text-blue-400 print:!text-blue-700">Product must:</span> {r.productMust}
            </p>
          </li>
        ))}
      </ol>

      <footer class="mt-6 border-t border-slate-200 pt-3 text-xs text-slate-400 dark:border-slate-700">
        Generated from the DRCDrivers interactive explainer. Drive the full road for the why behind each line.
      </footer>
    </article>
  </div>

  <script>
    document.getElementById('printBtn')?.addEventListener('click', () => window.print());
  </script>
</Base>
