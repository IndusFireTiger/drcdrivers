---
import ThemeToggle from '../components/ThemeToggle.jsx';
import TopNav from '../components/TopNav.jsx';

// The shared page shell. Every page gets the same container width, the same
// padding and the same nav row from here — pages render their content only.
// `current` is the TopNav key to mark active; omit it for pages that aren't a
// top-level destination (lessons and the cheat-sheet sit under the road) so the
// nav stays fully navigable.
const { title = 'DRCDrivers — Data Risk & Compliance, interactively', current } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <script is:inline>
      // Set theme before paint to avoid a flash of the wrong theme.
      (function () {
        try {
          var t = localStorage.getItem('drcdrivers:theme');
          var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          if (t === 'dark' || (!t && prefersDark)) {
            document.documentElement.classList.add('dark');
          }
        } catch (e) {}
      })();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="An interactive, end-to-end explainer of Data Risk & Compliance for technical product-builders." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-slate-50 text-slate-900 antialiased transition-colors dark:bg-slate-900 dark:text-slate-100">
    <ThemeToggle client:load />
    {/* The nav sits on its own surface — a full-bleed dark band that reads as a
        bar against the page in both themes (white on slate-50 was too close to
        register). Dark in light mode and dark mode alike, so the nav keeps one
        set of link colours. The inner container matches the content container
        below, so the links stay aligned with the page. */}
    <header class="border-b border-slate-700 bg-slate-800 shadow-sm dark:border-slate-600 dark:bg-slate-700 print:hidden">
      <div class="mx-auto w-full max-w-[120rem] px-6 py-3">
        <TopNav current={current} />
      </div>
    </header>
    <div class="mx-auto w-full max-w-[120rem] px-6 py-10">
      <slot />
    </div>
  </body>
</html>
